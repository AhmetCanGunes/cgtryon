rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the authenticated user owns this resource
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper: check if the user has admin custom claim
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Users can read their own document; admins can read any
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own document (registration)
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.credits is number
        && request.resource.data.credits >= 0;

      // Users can update their own document with restrictions:
      // - Cannot change uid, email, plan, or set credits to arbitrary values
      // - Can update: displayName, avatarId, lastLogin
      // - Can decrement credits (via useCredits) but not increment
      // - Can append to usageHistory
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.credits <= resource.data.credits;

      // Admins can update any user (add credits, change plan, etc.)
      allow update: if isAdmin();

      // Users cannot delete their own document; admins can
      allow delete: if isAdmin();
    }

    // ==========================================
    // IMAGE HISTORY COLLECTION
    // ==========================================
    match /imageHistory/{imageId} {
      // Users can only read their own images
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;

      // Users can create images only for themselves
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;

      // Users can update their own images (toggle favorite)
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid;

      // Users can delete their own images
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;

      // Admins can read/write/delete any image
      allow read, write, delete: if isAdmin();
    }

    // ==========================================
    // EMAIL SUBSCRIPTIONS COLLECTION
    // ==========================================
    match /emailSubscriptions/{subId} {
      // Anyone can create a subscription (landing page form)
      allow create: if true;

      // Only admins can read or delete subscriptions
      allow read, delete: if isAdmin();

      // No updates allowed
      allow update: if false;
    }

    // ==========================================
    // DEFAULT: Deny everything else
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
